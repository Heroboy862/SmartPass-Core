rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net Default catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Standard high-reliability validator primitives
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Validate User Profile Creation and Modification schemas
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email'])
        && data.keys().size() >= 2
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() > 0 && data.email.size() <= 150;
    }

    // Validate Flight State and Simulation variables
    function isValidFlight(data) {
      return data.keys().hasAll(['flightNumber'])
        && data.keys().size() >= 1
        && data.flightNumber is string && data.flightNumber.size() > 0 && data.flightNumber.size() <= 40;
    }

    // Users (Passenger Profile) Collection rules
    match /users/{userId} {
      allow read: if true;
      allow create, update: if isValidId(userId) && isValidUser(incoming());
      allow delete: if isValidId(userId);
    }

    // Flights Configuration rules
    match /flights/{flightId} {
      allow read: if true;
      allow create, update: if isValidId(flightId) && isValidFlight(incoming());
      allow delete: if isValidId(flightId);
    }

    // Secure, append-only, immutable security tracking audit logs (KVKK Rule Match)
    match /audit_logs/{logId} {
      allow get, list, create: if true;
    }
  }
}
