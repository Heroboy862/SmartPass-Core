rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net default catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Users Collection rules - Allows live simulation and visitor profiles registration
    match /users/{userId} {
      allow read, write: if true;
    }

    // Flights Configuration rules - Allows real-time synchronization from the aviation simulation console
    match /flights/{flightId} {
      allow read, write: if true;
    }
  }
}
