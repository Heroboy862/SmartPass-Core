# .env.example dosyası (GitHub'a yüklenecek)
# =========================================================================
# AeroAI Smart Boarding - Environment Variables Configuration Template
# =========================================================================

# 🤖 GEMINI AI STUDIO API CONFIGURATION
# -------------------------------------------------------------------------
# GEMINI_API_KEY: Akıllı asistan ve dinamik havacılık akışlarının AI motoru için gereklidir.
GEMINI_API_KEY="your_gemini_api_key_here"

# 🌐 VERİTABANI VE SUNUCU YAPILANDIRMASI (Genel Standart Değişken Şablonu)
# -------------------------------------------------------------------------
GOOGLE_API_KEY=your_api_key_here
DB_PASSWORD=your_database_password_here
PORT=3000

# 📧 OTOMATİK BİNİŞ İLETİŞİMLERİ (SMTP YAPILANDIRMASI)
# -------------------------------------------------------------------------
# Yolculara biniş kartı, bento akış planları ve engelsiz asistan planları 
# göndermek için kullanılan SMTP ayarları. Boş bırakılırsa e-postalar simülasyon olarak çalışır.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=

# 🛡️ GÜVENLİK VE SİMÜLASYON YÖNETİMİ
# -------------------------------------------------------------------------
# Üretim (production) ortamında simülasyon API'lerini kilitlemek için gerekli anahtar.
SIMULATION_API_KEY=
JWT_SECRET=your_jwt_secret_here


# 💵 KURUMSAL DÖVİZ VE ULAŞIM ENTEGRASYONLARI
# -------------------------------------------------------------------------
# Döviz kurları servisinin canlı API (open.er-api.com) çöktüğünde veya yavaşladığında devralacak yedek TRY kurları:
FALLBACK_USD=38.85
FALLBACK_EUR=42.20
FALLBACK_GBP=50.45
FALLBACK_RUB=0.39

# Ulaşım Entegrasyonu Aktif Sağlayıcı Stratejisi (STATIC | CMS | OPERATOR_API)
TRANSPORT_PROVIDER_STRATEGY=CMS


