# =========================================================================
# AeroAI Smart Boarding - Environment Variables Configuration Template
# =========================================================================
#
# This file serves as a template of all environment parameters required by the 
# application. In production, these parameters are managed securely by the Cloud Run 
# control plane. In local or preview setups, define them in a '.env' file.
#
# DO NOT add production secrets or real values here. This file is safely tracked 
# by Git, while any actual '.env' files are strictly ignored via '.gitignore'.
#
# =========================================================================

# 🤖 GEMINI AI STUDIO API CONFIGURATION
# -------------------------------------------------------------------------
# GEMINI_API_KEY: Required to power the AeroAI Chat Travel Assistant and
# smart boarding recommendations.
#
# SECURITY COMPLIANCE NOTE: Accessed strictly server-side (using process.env, 
# equivalent to os.getenv in Python runtimes) to avoid any browser leakage.
GEMINI_API_KEY="AIzaSyYourSecretGeminiAPIKeyHere"

# 🌐 WEB HOSTING & INTEGRATIONS
# -------------------------------------------------------------------------
# APP_URL: The public or preview hosting URL where this application template is run.
# Automatically supplied at runtime by Google AI Studio's Cloud Run sandbox.
APP_URL="https://your-sandbox-app-url.run.app"

# 📧 AUTOMATED ONBOARDING COMMUNICATIONS (SMTP CONFIG)
# -------------------------------------------------------------------------
# Optional: Setup actual SMTP settings to dispatch accessibility flight plans 
# and smart codes directly to the passenger. If left blank, the app runs in 
# a high-fidelity Sandbox Simulation mode automatically.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=

# 🗄️ PERSISTENT STORAGE / FIREBASE NOTES
# -------------------------------------------------------------------------
# Firebase and Firestore are integrated via secure Workspace JSON configurations
# (see firebase-applet-config.json) provisioned dynamically by the platform.
# No custom client-side API secrets or DB credentials need to be exposed here.
# =========================================================================
